{
  "name": "cyber-response-cymru",
  "type": "module",
  "version": "2.0.0-alpha.1",
  "private": true,
  "description": "Cyber Incident Response Planner for Welsh Schools — Astro architecture port of v0.1.0",
  "scripts": {
    "dev": "astro dev",
    "dev:clean": "node scripts/dev-clean.mjs",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "examples": "tsx scripts/generate-examples.mts",
    "extract:glyphs": "node scripts/extract-brand-glyphs.mjs",
    "generate:brand-image": "node scripts/generate-brand-image.mjs",
    "generate:og-image": "node scripts/generate-og-image.mjs",
    "generate:apple-icon": "node scripts/generate-apple-icon.mjs",
    "e2e": "playwright test",
    "e2e:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/react": "^4.2.1",
    "@astrojs/tailwind": "^6.0.0",
    "astro": "^5.1.5",
    "docx": "^9.6.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  },
  "devDependencies": {
    "@fontsource/fraunces": "^5.2.9",
    "@playwright/test": "^1.60.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitest/coverage-v8": "^2.1.8",
    "jsdom": "^29.1.1",
    "jszip": "^3.10.1",
    "opentype.js": "^2.0.0",
    "tsx": "^4.22.0",
    "vitest": "^2.1.8"
  }
