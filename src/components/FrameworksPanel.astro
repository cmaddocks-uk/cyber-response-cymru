---
// Home-page "Mapped to Welsh Frameworks" panel. Visual anchor for the
// credibility story — four colour-coded framework cards in a 2×2 grid,
// each clickable to source guidance, plus a Wales-gap callout and a
// "planning tool, not compliance pass" footer.
const SOURCES_VERIFIED = '29 April 2026';

const frameworks = [
  {
    name: 'NCSC',
    detail: 'Incident Management collection',
    url: 'https://www.ncsc.gov.uk/collection/incident-management',
    tone: 'ncsc',
  },
  {
    name: 'Welsh Government',
    detail: 'Cyber Resilient Wales strategy',
    url: 'https://www.gov.wales/cyber-resilient-wales-strategy',
    tone: 'dfe',
  },
  {
    name: 'TARIAN ROCU',
    detail: 'Cyber PROTECT team (South Wales)',
    url: 'https://www.tarianrccu.org.uk/',
    tone: 'rpa',
  },
  {
    name: 'Estyn',
    detail: 'Inspection guidance & resources',
    url: 'https://www.estyn.gov.wales/inspection-guidance-resources',
    tone: 'ofsted',
  },
];

// Tailwind has to see complete class strings to tree-shake, so we map tone
// → full class strings rather than building them with string concatenation.
const toneClasses: Record<string, string> = {
  ncsc: 'bg-[#eaf2fd] border-[#cdd9ed] text-[#1f4ed8]',
  dfe: 'bg-[#fff4e6] border-[#f4dba0] text-[#a04500]',
  rpa: 'bg-[#e7f5ec] border-[#c5e6d1] text-[#0a6a30]',
  ofsted: 'bg-[#f3e8ff] border-[#dcc7ff] text-[#6b21a8]',
};
---

<div class="rounded-card border border-line bg-white p-4 md:p-[18px]">
  <div class="mb-3.5 flex items-start justify-between gap-3">
    <div>
      <div class="text-[11px] font-bold uppercase tracking-[.06em] text-muted">
        Mapped to Welsh Frameworks
      </div>
      <div class="mt-0.5 text-sm font-bold text-navy">
        Every readiness question and plan section is tagged
      </div>
    </div>
    <div class="text-right text-[11px] leading-[1.4] text-muted">
      <div>Sources verified</div>
      <div class="text-xs font-bold text-navy">{SOURCES_VERIFIED}</div>
    </div>
  </div>

  <div class="mb-3.5 grid grid-cols-1 gap-2.5 sm:grid-cols-2">
    {
      frameworks.map((f) => (
        <a
          href={f.url}
          target="_blank"
          rel="noopener noreferrer"
          class={`grid grid-cols-[1fr_auto] items-center gap-x-2.5 gap-y-1 rounded-lg border p-3.5 no-underline transition hover:-translate-y-px hover:shadow-md hover:no-underline ${toneClasses[f.tone]}`}
        >
          <div class="col-start-1 row-start-1 text-[13px] font-extrabold tracking-[.01em]">
            {f.name}
          </div>
          <div class="col-start-1 row-start-2 text-[12px] leading-[1.3] opacity-85">
            {f.detail}
          </div>
          <div class="col-start-2 row-span-2 self-center text-lg font-bold opacity-65">
            →
          </div>
        </a>
      ))
    }
  </div>

  <div
    class="mb-3.5 flex items-center gap-2.5 rounded-md border border-[#cdd9ed] border-l-4 border-l-accent bg-gradient-to-r from-[#eaf2fd] to-[#f7f9fc] p-2.5 px-3.5 text-[13px] text-navy"
  >
    <span class="shrink-0 text-lg">🏛️</span>
    <span class="flex-1 leading-[1.4]">
      <strong>Wales has no DfE-style sector cyber hub</strong> — sector-specific
      incident response planning support for Welsh schools is a real gap. This
      tool exists to fill it, working alongside NCSC guidance, the Welsh
      Government Cyber Resilient Wales strategy and the regional ROCU Cyber
      PROTECT teams (TARIAN and NWROCU).
    </span>
  </div>

  <div class="flex items-start gap-2.5 rounded-md bg-[#f7f9fc] p-2.5 px-3 text-[12.5px] leading-[1.5] text-ink">
    <span class="text-sm">💡</span>
    <div>
      <strong>A planning tool, not a compliance pass.</strong> Designed to
      <strong>complement</strong> the frameworks above, not replace them. Use
      alongside your business continuity and disaster recovery plans. For the
      <strong>prevention</strong> side, see also
      <a href="https://www.ncsc.gov.uk/cyberessentials/overview" target="_blank" rel="noopener noreferrer">
        Cyber Essentials</a
      >.
    </div>
  </div>
</div>
