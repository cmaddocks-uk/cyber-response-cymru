---
import BaseLayout from '~/layouts/BaseLayout.astro';
import FrameworksPanel from '~/components/FrameworksPanel.astro';
import BrandMark from '~/components/BrandMark.astro';
import { withBase } from '~/lib/nav';

const VERSION = '2.0.0-alpha.1';

// Plan-builder section overview tiles. Kept as data so the home page and
// the future Plan Builder index can share the same source.
const planSections = [
  { id: 'meta', label: 'School details', icon: '🏫', tone: 'bg-[#e8efff] text-[#1f4ed8]' },
  { id: 'team', label: 'Response team', icon: '👥', tone: 'bg-[#e7f5ec] text-success' },
  { id: 'contacts_external', label: 'External contacts', icon: '📞', tone: 'bg-[#fff4e6] text-[#a04500]' },
  { id: 'severity', label: 'Severity & triage', icon: '⚠️', tone: 'bg-[#fbe9e7] text-danger' },
  { id: 'escalation', label: 'Escalation', icon: '🎯', tone: 'bg-[#f3e8ff] text-[#6b21a8]' },
  { id: 'playbooks', label: 'Playbooks', icon: '📋', tone: 'bg-[#fdf3e2] text-warning' },
  { id: 'comms', label: 'Communications', icon: '📢', tone: 'bg-[#e8efff] text-[#1f4ed8]' },
  { id: 'recovery', label: 'Recovery', icon: '💾', tone: 'bg-[#e7f5ec] text-success' },
  { id: 'review', label: 'Post-incident review', icon: '🔍', tone: 'bg-[#f0f4fa] text-navy-2' },
  { id: 'maintenance', label: 'Plan maintenance', icon: '🔄', tone: 'bg-[#f3e8ff] text-[#6b21a8]' },
];
---

<BaseLayout>
  <!-- HERO -->
  <section class="py-6 text-center md:py-7">
    <div class="mb-2 flex justify-center"><BrandMark variant="dark" size={56} /></div>
    <h1 class="m-0 mb-2.5 text-[30px] font-extrabold leading-[1.15] tracking-tight text-navy">
      Cyber Incident Response Planner
    </h1>
    <p class="mx-auto mb-4 max-w-[620px] text-[15px] leading-[1.5] text-muted">
      Free planning tool for Welsh schools and colleges. Build a school-specific
      Cyber Incident Response Plan, mapped to NCSC, Welsh Government Cyber
      Resilient Wales and Estyn inspection arrangements.
    </p>

    <a
      href={withBase('/readiness')}
      class="inline-block min-w-[260px] rounded-lg bg-accent px-8 py-3 text-[15px] font-bold text-white shadow-[0_2px_0_#1657b8,0_6px_18px_rgba(31,111,235,.18)] no-underline transition hover:-translate-y-px hover:bg-[#1657b8] hover:!no-underline"
    >
      ▶ Start readiness check
    </a>
    <p class="m-0 mt-2.5 text-xs text-muted">
      Takes around 15–25 minutes · readiness check · 10-section plan builder
    </p>

    <div class="mt-3.5 flex flex-wrap justify-center gap-2">
      <span class="inline-block rounded-full border border-[#cdd9ed] bg-[#eaf2fd] px-3.5 py-1.5 text-[13px] font-semibold text-accent">
        ✓ Free · browser-only · no account
      </span>
      <span class="inline-block rounded-full border border-[#cdd9ed] bg-[#eaf2fd] px-3.5 py-1.5 text-[13px] font-semibold text-accent">
        ✓ Mapped to NCSC, Welsh Gov, Estyn &amp; TARIAN
      </span>
    </div>
    <div class="mt-3 text-[11px] font-semibold uppercase tracking-[.04em] text-muted">
      v{VERSION} ·
      <a href={withBase('/changelog')}>changelog</a>
    </div>
  </section>

  <!-- Police CyberAlarm callout — sector-current information about PCA
       registrations staying open during the transition period. Compact,
       expandable. Same content as v1.7.0 verbatim. -->
  <details
    class="mb-5 rounded-md border border-[#cdd9ed] border-l-4 border-l-accent bg-[#eaf2fd] p-2.5 px-3.5"
  >
    <summary class="flex cursor-pointer list-none items-start gap-2 text-[13px] leading-[1.5] text-navy">
      <span class="mt-px shrink-0 text-sm">ℹ️</span>
      <span class="flex-1">
        <strong>Police CyberAlarm:</strong> registrations remain open and vulnerability scanning
        is available — a free baseline control for Welsh schools.{' '}
        <span class="whitespace-nowrap text-xs font-bold text-accent">More info ↓</span>
      </span>
    </summary>
    <div class="mt-2.5 border-t border-[#cdd9ed] pl-5.5 pt-2.5 text-[13px] leading-[1.55] text-ink">
      <p class="mb-1.5">
        Only the on-network data collector is currently paused for new installations during a
        planned transition period — the rest of the service continues as usual. If you're unsure
        about your specific position, your regional ROCU Cyber PROTECT team can advise free of
        charge:{' '}
        <a
          href="https://www.tarianrccu.org.uk/"
          target="_blank"
          rel="noopener noreferrer">TARIAN</a> covers South Wales, Gwent and Dyfed-Powys; {' '}
        <a
          href="https://www.nwrocu.police.uk/"
          target="_blank"
          rel="noopener noreferrer">NWROCU</a> covers North Wales. The full registration page is
        at {' '}
        <a href="https://www.cyberalarm.police.uk/register/" target="_blank" rel="noopener noreferrer">
          cyberalarm.police.uk</a>.
      </p>
      <p class="m-0 text-xs text-muted">
        Wales does not have a national risk protection scheme equivalent to the DfE's RPA. Most
        maintained Welsh schools are covered through their local authority's cyber and IT
        insurance arrangement — record your LA cyber lead and any policy reference in the
        External Contacts section of the plan.
      </p>
    </div>
  </details>

  <!-- Cloud MIS / SaaS data-controller callout — UK GDPR data-controller
       reminder. Mentions Arbor, SIMS Cloud, Bromcom, etc., and links to the
       Plan Builder Assets section, the SaaS supplier playbook, and Tabletop
       scenario F. -->
  <details
    class="mb-5 rounded-md border border-[#f4dba0] border-l-4 border-l-warning bg-[#fef9e7] p-2.5 px-3.5"
  >
    <summary class="flex cursor-pointer list-none items-start gap-2 text-[13px] leading-[1.5] text-navy">
      <span class="mt-px shrink-0 text-sm">☁️</span>
      <span class="flex-1">
        <strong>Cloud MIS / SaaS:</strong> do you hold your own copy of the data? If your MIS or
        pupil-data SaaS is supplier-hosted, you remain the <strong>data controller</strong> under
        UK GDPR. <span class="whitespace-nowrap text-xs font-bold text-accent">More info ↓</span>
      </span>
    </summary>
    <div class="mt-2.5 border-t border-[#f4dba0] pl-5.5 pt-2.5 text-[13px] leading-[1.55] text-ink">
      <p class="mb-1.5">
        When your MIS (<strong>Arbor</strong>, <strong>SIMS Cloud</strong>, <strong>Bromcom</strong>,
        <strong>iSAMS</strong>, <strong>Engage</strong>, <strong>ScholarPack</strong>) or other
        school-data SaaS (<strong>CPOMS</strong>, <strong>MyConcern</strong>,
        <strong>ParentPay</strong>, <strong>M365</strong>) is hosted by the supplier, you are
        still the data controller and they are the data processor.{' '}
        <strong>Best practice: request and store a current export of your school's data termly</strong>,
        separate from the supplier's environment. If they suffer a breach, fold, or you need to
        migrate, you can act independently &mdash; without waiting for the supplier's recovery
        timeline or commercial co-operation.
      </p>
      <p class="mb-1.5">
        Most schools never test this until it's too late. The{' '}
        <a href={withBase('/plan')}>Critical systems &amp; impact section</a> in the Plan Builder
        includes a "Last data export from supplier" field for each system; the{' '}
        <a href={withBase('/plan')}>SaaS supplier incident playbook</a> walks the response when a
        supplier-hosted system is breached; the{' '}
        <a href={withBase('/tabletop')}>Tabletop scenario F</a> tests this against a cloud /
        ransomcloud incident.
      </p>
      <p class="m-0 text-xs text-muted">
        Why this matters in practice: if Arbor (or your MIS supplier) suffers a serious breach,
        the <strong>72-hour ICO notification clock falls on you</strong>, not them. Without your
        own data copy, you can't quickly answer "what data was held?", brief parents under UK
        GDPR Article 34, or maintain operational continuity. Add the termly data-export task to
        your annual cyber calendar (Plan section 12.1).
      </p>
    </div>
  </details>

  <!-- Two-column hero block: Frameworks panel left, jump-links right -->
  <div class="grid grid-cols-1 items-stretch gap-3 lg:grid-cols-2">
    <div class="flex flex-col gap-4 rounded-[12px] border border-line border-t-4 border-t-accent bg-white p-5 shadow-card">
      <FrameworksPanel />
    </div>

    <div class="flex flex-col gap-4">
      <div class="flex-1 rounded-[12px] border border-line border-t-4 border-t-accent bg-white p-6 shadow-card">
        <h2 class="m-0 mb-1 text-xl font-bold text-navy">Already started?</h2>
        <p class="m-0 mb-4 text-[13px] text-muted">
          Jump straight to a specific section of the tool.
        </p>

        {
          [
            { label: '📋 Plan builder', href: '/plan' },
            { label: '🎯 Prioritised action plan', href: '/action-plan' },
            { label: '🎯 Tabletop exercise', href: '/tabletop' },
            { label: '📊 Governor report', href: '/governor' },
            { label: '🚨 First 30 Minutes card', href: '/first-30' },
          ].map((link) => (
            <a
              href={withBase(link.href)}
              class="mb-1.5 block w-full rounded-lg border border-line bg-white px-4 py-3 text-center text-sm font-semibold text-navy no-underline transition hover:border-accent hover:bg-[#f0f4fa] hover:text-accent hover:!no-underline"
            >
              {link.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>

  <!-- Plan section overview -->
  <div class="card mt-3">
    <div class="mb-3.5 flex flex-wrap items-baseline justify-between gap-2.5">
      <div class="text-[11px] font-bold uppercase tracking-[.05em] text-muted">
        PLAN COVERS 10 SECTIONS
      </div>
      <a href={withBase('/plan')} class="text-xs font-semibold text-accent">
        Open the plan builder →
      </a>
    </div>
    <div class="grid grid-cols-2 gap-1.5 sm:grid-cols-3 lg:grid-cols-5">
      {
        planSections.map((s) => (
          <a
            href={withBase(`/plan#${s.id}`)}
            class="flex items-center gap-3 rounded-lg border border-line bg-[#f7f9fc] px-3.5 py-3 text-[13.5px] font-semibold text-navy-2 no-underline transition hover:-translate-y-px hover:border-accent hover:bg-white hover:shadow-card hover:!no-underline"
          >
            <span class={`inline-flex h-[30px] w-[30px] shrink-0 items-center justify-center rounded-md text-[15px] ${s.tone}`}>
              {s.icon}
            </span>
            {s.label}
          </a>
        ))
      }
    </div>
  </div>

  <!-- Sister tool / feedback row -->
  <div class="grid grid-cols-1 gap-2 md:grid-cols-2">
    <a
      href="https://cmaddocks-uk.github.io/cyber-response/"
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-3.5 rounded-[12px] border border-line bg-white p-5 text-ink no-underline shadow-card transition hover:-translate-y-px hover:shadow-lg hover:!no-underline"
    >
      <span class="shrink-0 text-3xl leading-none">🇬🇧</span>
      <span class="flex-1">
        <span class="block text-[11px] font-bold uppercase tracking-[.05em] text-muted">
          Sister tool (England)
        </span>
        <span class="mt-0.5 block text-[15px] font-bold text-navy">
          Cyber Incident Response Planner — for UK schools and colleges
        </span>
        <span class="mt-0.5 block text-xs leading-[1.4] text-muted">
          English-context fork: DfE Cyber Security Hub, DfE Digital Standards 2030, RPA, Ofsted.
        </span>
      </span>
      <span class="shrink-0 text-lg font-bold text-accent">→</span>
    </a>

    <div class="rounded-[12px] border border-[#cdd9ed] bg-[#eaf2fd] p-4">
      <h3 class="mb-1.5 flex items-center gap-2 text-[15px] font-bold text-navy">
        💬 Help us improve this tool
      </h3>
      <p class="mb-3 text-[13px] text-ink">
        Tried the tool? Tell us what worked and what didn't — your feedback
        shapes future versions.
      </p>
      <a
        class="block w-full rounded-lg bg-accent px-4 py-3 text-center text-sm font-semibold text-white no-underline transition hover:bg-[#1657b8] hover:!text-white hover:!no-underline"
        href="https://forms.gle/5T11PrusSaRHBwab7"
        target="_blank"
        rel="noopener noreferrer"
      >
        💭 Share your feedback
      </a>
    </div>
  </div>

  <!-- Brand footer — full Lockup A (disc + Fraunces CIRP + Plex descriptor) -->
  <div class="no-print mt-8 flex items-center justify-center gap-3 border-t border-line pt-6">
    <BrandMark variant="dark" size={44} />
    <div class="flex flex-col leading-none">
      <span class="font-bold tracking-tight text-navy" style="font-family: Fraunces, Georgia, serif; font-size: 26px;">CIRP™</span>
      <span class="mt-1.5 text-[10px] font-semibold uppercase tracking-[.06em] text-muted">
        Cynllun Ymateb i Achosion Seiber
      </span>
    </div>
  </div>

  <!-- Status bar / footer links -->
  <div class="no-print mt-4 flex flex-wrap items-center justify-center gap-1.5 pt-2">
    <span class="inline-block rounded-full border border-[#c5e6d1] bg-success-soft px-3 py-1 text-xs font-bold tracking-[.02em] text-success">
      ✓ v{VERSION} current
    </span>
    {
      [
        { label: '📘 Welsh Gov ↗', href: 'https://www.gov.wales/cyber-resilient-wales-strategy' },
        { label: '🛡️ TARIAN ↗', href: 'https://www.tarianrccu.org.uk/' },
        { label: '🏛️ Estyn ↗', href: 'https://www.estyn.gov.wales/inspection-guidance-resources' },
        { label: '🌐 HWB ↗', href: 'https://hwb.gov.wales/' },
        { label: '🛡️ NCSC ↗', href: 'https://www.ncsc.gov.uk/collection/incident-management' },
        { label: '🔒 Cyber Essentials ↗', href: 'https://www.ncsc.gov.uk/cyberessentials/overview' },
      ].map((link) => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block rounded-full border border-line bg-white px-3 py-1 text-xs font-semibold text-navy-2 no-underline transition hover:border-accent hover:bg-[#f0f4fa] hover:text-accent hover:!no-underline"
        >
          {link.label}
        </a>
      ))
    }
    <a
      href={withBase('/changelog')}
      class="inline-block rounded-full border border-line bg-white px-3 py-1 text-xs font-semibold text-navy-2 no-underline transition hover:border-accent hover:bg-[#f0f4fa] hover:text-accent hover:!no-underline"
    >
      📋 Changelog
    </a>
    <a
      href={withBase('/about')}
      class="inline-block rounded-full border border-line bg-white px-3 py-1 text-xs font-semibold text-navy-2 no-underline transition hover:border-accent hover:bg-[#f0f4fa] hover:text-accent hover:!no-underline"
    >
      ℹ️ About
    </a>
  </div>
</BaseLayout>
