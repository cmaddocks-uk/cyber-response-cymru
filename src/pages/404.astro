---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { withBase } from '~/lib/nav';

// Astro auto-emits this as 404.html in the build output, which GitHub Pages
// serves for any unmatched path. Mirrors the v1.x standalone 404 page —
// explicit disclaimer of Power Automate / webhook / payment / OAuth endpoints
// so anyone arriving via a fake URL using this domain sees a clear
// "this site doesn't host that" message.
---

<BaseLayout
  title="Page not found — Cyber Incident Response Planner"
  description="That page doesn't exist. The Cyber Incident Response Planner is a static planning tool — no APIs, webhooks or payment endpoints."
>
  <div class="card mx-auto max-w-[560px] border-t-4 border-t-accent">
    <span class="mb-4 inline-block rounded-full bg-danger-soft px-2.5 py-1 text-[11px] font-bold uppercase tracking-[.06em] text-danger">
      404 — Not Found
    </span>
    <h1 class="m-0 mb-3 text-[28px] font-extrabold leading-[1.2] tracking-tight text-navy">
      That page doesn't exist here.
    </h1>
    <p class="m-0 mb-3">
      You may have followed a stale link, or a URL that was never hosted on this domain.
    </p>
    <p class="m-0 mb-3">
      This domain hosts the <strong>Cyber Incident Response Planner</strong> — a free planning tool for Welsh schools and colleges.
    </p>

    <div class="mt-5 flex flex-col gap-2 border-t border-line pt-4 text-[15px]">
      <a href={withBase('/')}>→ Go to the Cyber Incident Response Planner</a>
      <a href="https://cmaddocks-uk.github.io/cyber-response/" target="_blank" rel="noopener noreferrer">
        → Sister tool (England) — Cyber Incident Response Planner
      </a>
      <a href="https://github.com/cmaddocks-uk/cyber-response-cymru/issues" target="_blank" rel="noopener noreferrer">
        → Report a broken link on GitHub
      </a>
    </div>

    <p class="mt-4 text-xs leading-[1.5] text-muted">
      If you arrived via an unfamiliar URL pretending to be from this site
      (Power Automate webhook, Microsoft 365 trigger, payment portal, etc.) —
      that wasn't us. This site only hosts public, static planning tools for schools.
    </p>
  </div>
</BaseLayout>
