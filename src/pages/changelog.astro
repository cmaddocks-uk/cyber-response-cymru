---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';

// Entries live in src/content/changelog/*.md and are schema-validated by
// src/content/config.ts. Sort: newest date first; within the same date,
// newest semantic version first. String sorting puts 2.6.10 before 2.6.2,
// so we compare numerically by part.
type Entry = CollectionEntry<'changelog'>;
type Tag = 'Feature' | 'Fix' | 'Security' | 'UI' | 'Breaking';

function compareSemver(a: string, b: string): number {
  // Strip any "-pre.0" suffix for the X.Y.Z compare; treat suffix as lower.
  const aMain = a.split('-')[0];
  const bMain = b.split('-')[0];
  const pa = aMain.split('.').map((n) => parseInt(n, 10) || 0);
  const pb = bMain.split('.').map((n) => parseInt(n, 10) || 0);
  for (let i = 0; i < 3; i++) {
    const va = pa[i] ?? 0;
    const vb = pb[i] ?? 0;
    if (va !== vb) return va - vb;
  }
  // Tiebreak: a clean version is greater than a pre-release on the same X.Y.Z.
  const aPre = a.includes('-');
  const bPre = b.includes('-');
  if (aPre && !bPre) return -1;
  if (!aPre && bPre) return 1;
  return a.localeCompare(b);
}

function inferTags(entry: Entry): Tag[] {
  if (entry.data.tags && entry.data.tags.length > 0) return entry.data.tags;
  // Fall back to a single badge derived from the bump level.
  if (entry.data.bump === 'major') return ['Breaking'];
  if (entry.data.bump === 'minor') return ['Feature'];
  if (entry.data.bump === 'patch') return ['Fix'];
  return [];
}

const allEntries = await getCollection('changelog');
allEntries.sort((a, b) => {
  const dateDiff = b.data.date.getTime() - a.data.date.getTime();
  if (dateDiff !== 0) return dateDiff;
  return compareSemver(b.data.version, a.data.version);
});

// Group consecutive entries with the same date under one date header.
type Group = { date: Date; entries: Entry[] };
const groups: Group[] = [];
for (const entry of allEntries) {
  const last = groups[groups.length - 1];
  if (last && last.date.getTime() === entry.data.date.getTime()) {
    last.entries.push(entry);
  } else {
    groups.push({ date: entry.data.date, entries: [entry] });
  }
}

const dateFmt = new Intl.DateTimeFormat('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

// Compact badge styling, aligned with the existing chip/pill palette.
const TAG_STYLE: Record<Tag, string> = {
  Feature:  'bg-[#eaf2fd] text-accent border-[#cdd9ed]',
  Fix:      'bg-[#e7f5ec] text-success border-[#c5e6d1]',
  Security: 'bg-[#fbe9e7] text-danger border-[#f4c6c0]',
  UI:       'bg-[#f3e8ff] text-[#6b21a8] border-[#d8c5ee]',
  Breaking: 'bg-[#fef9e7] text-warning border-[#f4dba0]',
};
---

<BaseLayout title="Changelog — Cyber Incident Response Planner">
  <div class="card py-4">
    <h2 class="m-0 mb-1 text-xl font-bold text-navy">Changelog</h2>
    <p class="m-0 text-sm text-muted">
      What's changed in the Cyber Incident Response Planner. Most recent first.
    </p>
  </div>

  {
    allEntries.length === 0 ? (
      <div class="card">
        <p class="m-0 text-sm italic text-muted">
          No changelog entries yet. Add markdown files to{' '}
          <code class="rounded bg-[#f7f9fc] px-1 text-xs">src/content/changelog/</code>.
        </p>
      </div>
    ) : (
      groups.map((group, groupIdx) => (
        <section class="mb-5">
          <h3 class="mb-2 mt-3 text-[11px] font-bold uppercase tracking-[.08em] text-muted">
            {dateFmt.format(group.date)}
          </h3>
          <div class="space-y-1.5">
            {group.entries.map(async (entry, entryIdx) => {
              const { Content } = await entry.render();
              const isLatest = groupIdx === 0 && entryIdx === 0;
              const tags = inferTags(entry);
              return (
                <details
                  class="group rounded-lg border border-line bg-white transition-shadow hover:shadow-card"
                  open={isLatest}
                >
                  <summary
                    class="flex cursor-pointer list-none items-center gap-2.5 rounded-lg px-3.5 py-2 text-[15px] font-bold text-navy outline-none transition-colors hover:bg-[#f7f9fc] focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2"
                  >
                    <svg
                      class="size-4 shrink-0 text-muted transition-transform duration-200 ease-out group-open:rotate-90"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <polyline points="9 18 15 12 9 6" />
                    </svg>

                    <span class="shrink-0 text-navy">v{entry.data.version}</span>

                    {isLatest && (
                      <span class="shrink-0 rounded-full border border-[#c5e6d1] bg-success-soft px-1.5 py-0.5 text-[9.5px] font-semibold uppercase tracking-[.06em] text-success">
                        Latest
                      </span>
                    )}

                    {tags.map((tag) => (
                      <span
                        class:list={[
                          'shrink-0 rounded border px-1.5 py-0.5 text-[9.5px] font-semibold uppercase tracking-[.06em]',
                          TAG_STYLE[tag],
                        ]}
                      >
                        {tag}
                      </span>
                    ))}

                    <span class="ml-1 hidden flex-1 truncate text-[13px] font-normal text-muted sm:block">
                      {entry.data.summary}
                    </span>
                  </summary>

                  <div class="prose prose-sm max-w-none border-t border-line/60 px-3.5 py-3 [&_blockquote]:my-3 [&_blockquote]:border-l-2 [&_blockquote]:border-line [&_blockquote]:pl-3 [&_blockquote]:text-sm [&_blockquote]:text-muted [&_a]:text-accent [&_h3]:mb-1.5 [&_h3]:mt-3 [&_h3]:text-[11px] [&_h3]:font-bold [&_h3]:uppercase [&_h3]:tracking-[.06em] [&_h3]:text-navy-2 [&_h3:first-child]:mt-0 [&_li]:mb-0.5 [&_p]:mb-2.5 [&_ul]:list-disc [&_ul]:pl-5">
                    <p class="!mb-3 hidden text-[13px] text-muted sm:hidden">
                      {entry.data.summary}
                    </p>
                    <Content />
                  </div>
                </details>
              );
            })}
          </div>
        </section>
      ))
    )
  }
</BaseLayout>
